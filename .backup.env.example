# Athena-Backup → NAS. Kopiere zu .backup.env und trage die echten Werte ein.
# .backup.env ist gitignored (enthält das rsync-Passwort).
#
# Eigenes rsync-MODUL "athena" auf dem gemeinsamen NAS-Receiver (Port 8873),
# Auth-User "athena". Modulname = Pfad-Segment in der URL:
NAS_RSYNC_TARGET=rsync://athena@<nas-tailscale-ip>:8873/athena
RSYNC_PASSWORD=<athena-rsync-passwort-wie-in-/etc/rsyncd.secrets-auf-dem-nas>
